
# Application
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ——— Database (Neon PostgreSQL) ———
# Pooled connection URL — used by the app at runtime
DATABASE_URL=""
# Direct (non-pooled) URL — used for migrations only (prisma migrate)
# DIRECT_URL=""

# ——— File storage (Cloudflare R2) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Public URL for serving images via next/image, e.g. https://pub-xxxx.r2.dev
# Required at runtime so proxied menu image URLs resolve for the image optimizer.
R2_PUBLIC_URL=""
