{
  "name": "lanj-menu",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --project tsconfig.typecheck.json --noEmit --incremental false",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "node scripts/seed-menu-structure.mjs",
    "db:import-lanj-pool": "node scripts/import-lanj-pool-menu.mjs",
    "db:ensure-pool-placeholder": "node scripts/ensure-pool-menu-placeholder.mjs",
    "db:rewrite-image-urls": "node scripts/rewrite-image-urls.mjs",
    "db:restore-menu": "node scripts/restore-real-menu-items.mjs",
    "db:sync-menu": "node scripts/sync-menu-items.mjs",
    "db:migrate-subcategories": "node scripts/migrate-subcategories-to-db.mjs",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@prisma/client": "^6.0.0",
    "dotenv": "^17.4.2",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.8"
  }
}
